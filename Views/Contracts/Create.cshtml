@model Website_QLPT.Models.Contract
@{
    ViewData["Title"] = "Tạo Hợp Đồng Mới";
}

<div class="page-header">
    <h1 class="page-title"><i class="bi bi-file-earmark-plus me-2 text-secondary"></i>Tạo Hợp Đồng Mới</h1>
    <a asp-action="Index" class="btn-qlpt btn-qlpt-secondary"><i class="bi bi-arrow-left"></i> Quay lại</a>
</div>

<div class="card-qlpt" style="max-width:700px;">
    <div class="card-qlpt-body">
        <form asp-action="Create" method="post" class="form-qlpt">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            @* Chọn phòng & khách thuê *@
            <div class="row g-3 mb-3">
                <div class="col-md-6">
                    <label class="form-label" style="font-size:13px;font-weight:600;">Phòng (đang trống)</label>
                    <select asp-for="RoomId" class="form-select" asp-items="ViewBag.RoomId">
                        <option value="">-- Chọn phòng --</option>
                    </select>
                    <span asp-validation-for="RoomId" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label class="form-label" style="font-size:13px;font-weight:600;">Khách thuê</label>
                    <select asp-for="TenantId" class="form-select" asp-items="ViewBag.TenantId">
                        <option value="">-- Chọn khách thuê --</option>
                    </select>
                    <span asp-validation-for="TenantId" class="text-danger small"></span>
                </div>
            </div>

            @* Ngày thuê *@
            <div class="row g-3 mb-3">
                <div class="col-md-6">
                    <label asp-for="StartDate"></label>
                    <input asp-for="StartDate" class="form-control" type="date" />
                    <span asp-validation-for="StartDate" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="EndDate"></label>
                    <input asp-for="EndDate" class="form-control" type="date" />
                    <small class="text-muted">Để trống nếu không xác định hạn.</small>
                </div>
            </div>

            @* Tiền cọc *@
            <div class="mb-3">
                <label asp-for="DepositAmount"></label>
                <div class="input-group">
                    <input asp-for="DepositAmount" class="form-control" placeholder="VD: 3000000" />
                    <span class="input-group-text" style="font-size:13px;color:#6b7280;background:#f9fafb;border-color:#e2e4e8;">VND</span>
                </div>
                <span asp-validation-for="DepositAmount" class="text-danger small"></span>
            </div>

            @* Ghi chú *@
            <div class="mb-4">
                <label asp-for="Note"></label>
                <textarea asp-for="Note" class="form-control" rows="2" placeholder="Các điều khoản đặc biệt, thỏa thuận thêm..."></textarea>
            </div>

            <div style="background:#fef9ec;border:1px solid #fde68a;border-radius:8px;padding:12px;margin-bottom:20px;font-size:13px;">
                <i class="bi bi-info-circle text-warning me-2"></i>
                Sau khi tạo hợp đồng, trạng thái phòng sẽ tự động chuyển thành <strong>"Đã cho thuê"</strong>.
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn-qlpt btn-qlpt-primary"><i class="bi bi-check-lg"></i> Tạo hợp đồng</button>
                <a asp-action="Index" class="btn-qlpt btn-qlpt-secondary">Hủy</a>
            </div>
        </form>
    </div>
</div>
