@model X.PagedList.IPagedList<Website_QLPT.Models.Room>
@{
    Layout = "_PublicLayout";
    ViewData["Title"] = "Tất Cả Phòng Trống";
}

<div class="container-fluid px-3">
    <div class="row g-3">
        <!-- ======= LEFT SIDEBAR ======= -->
        <div class="col-lg-2 col-md-3">
            <div class="widget">
                <div class="widget-header">
                    <i class="bi bi-funnel-fill"></i> Lọc Phòng
                </div>
                <div class="widget-body p-2">
                    <form method="get" asp-controller="Home" asp-action="AllRooms">
                        <div class="mb-2">
                            <label class="form-label text-muted" style="font-size:0.75rem; font-weight:700;">TỪ KHOÁ</label>
                            <input type="text" name="keyword" class="form-control form-control-sm"
                                   value="@ViewBag.Keyword" placeholder="Tên phòng, khu nhà...">
                        </div>
                        <div class="mb-2">
                            <label class="form-label text-muted" style="font-size:0.75rem; font-weight:700;">GIÁ TỪ (VNĐ)</label>
                            <input type="number" name="minPrice" min="0" step="500000" class="form-control form-control-sm"
                                   value="@ViewBag.MinPrice" placeholder="VD: 1000000">
                        </div>
                        <div class="mb-3">
                            <label class="form-label text-muted" style="font-size:0.75rem; font-weight:700;">ĐẾN GIÁ (VNĐ)</label>
                            <input type="number" name="maxPrice" min="0" step="500000" class="form-control form-control-sm"
                                   value="@ViewBag.MaxPrice" placeholder="Không giới hạn">
                        </div>
                        <button type="submit" class="btn w-100 btn-sm text-white fw-700"
                                style="background:var(--primary); border-radius:8px; font-weight:700;">
                            <i class="bi bi-search me-1"></i>Tìm kiếm
                        </button>
                        @if (ViewBag.Keyword != null || ViewBag.MinPrice != null || ViewBag.MaxPrice != null)
                        {
                            <a asp-controller="Home" asp-action="AllRooms"
                               class="btn btn-outline-secondary w-100 btn-sm mt-2" style="border-radius:8px;">
                                <i class="bi bi-x-circle me-1"></i>Xoá bộ lọc
                            </a>
                        }
                    </form>
                </div>
            </div>

            <!-- Về trang chủ -->
            <div class="widget">
                <div class="widget-body p-2 text-center">
                    <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary btn-sm w-100" style="border-radius:8px;">
                        <i class="bi bi-house-fill me-1"></i>Về Trang Chủ
                    </a>
                </div>
            </div>
        </div><!-- /LEFT SIDEBAR -->

        <!-- ======= MAIN CONTENT ======= -->
        <div class="col-lg-10 col-md-9">
            <div class="section-header">
                <i class="bi bi-grid-3x3-gap-fill text-primary"></i>
                <h2>Tất Cả Phòng Trống</h2>
                <span class="section-count">@ViewBag.TotalCount phòng · Trang @Model.PageNumber / @Model.PageCount</span>
            </div>

            @if (Model.Any())
            {
                <div class="row g-3">
                    @foreach (var room in Model)
                    {
                        var thumb = room.Images?.FirstOrDefault(i => i.IsThumbnail)?.ImagePath
                                 ?? room.Images?.FirstOrDefault()?.ImagePath
                                 ?? "https://images.unsplash.com/photo-1505873242700-f289a29e1e0f?w=600&q=80";
                        <div class="col-md-3 col-sm-6">
                            <div class="room-card">
                                <div style="position:relative; overflow:hidden;">
                                    <img src="@thumb" alt="@room.Name" style="width:100%; height:165px; object-fit:cover; transition:transform 0.3s;">
                                    <div style="position:absolute; top:8px; right:8px; background:var(--accent); color:#fff; font-size:0.7rem; font-weight:700; padding:2px 8px; border-radius:20px;">
                                        Trống
                                    </div>
                                </div>
                                <div class="card-body p-3">
                                    <div class="room-name">@room.Name</div>
                                    <div class="room-meta">
                                        <i class="bi bi-geo-alt-fill text-danger me-1"></i>
                                        @(room.Property?.Name ?? "Khu nhà")
                                    </div>
                                    <div class="d-flex justify-content-between align-items-center mt-2">
                                        <span style="font-size:0.78rem; color:#64748b;">
                                            <i class="bi bi-rulers me-1"></i>@room.Area m²
                                        </span>
                                        <span class="room-price" style="font-size:0.95rem;">@room.Price.ToString("N0") đ</span>
                                    </div>
                                    <a asp-controller="Home" asp-action="RoomDetails" asp-route-id="@room.Id" class="btn-view">
                                        <i class="bi bi-eye me-1"></i>Xem chi tiết
                                    </a>
                                </div>
                            </div>
                        </div>
                    }
                </div>

                <!-- Pagination -->
                @if (Model.PageCount > 1)
                {
                    <nav aria-label="Phân trang" class="mt-4 d-flex justify-content-center">
                        <ul class="pagination pagination-sm">
                            @if (Model.HasPreviousPage)
                            {
                                <li class="page-item">
                                    <a class="page-link" asp-action="AllRooms"
                                       asp-route-page="@(Model.PageNumber - 1)"
                                       asp-route-keyword="@ViewBag.Keyword"
                                       asp-route-minPrice="@ViewBag.MinPrice"
                                       asp-route-maxPrice="@ViewBag.MaxPrice">
                                        <i class="bi bi-chevron-left"></i>
                                    </a>
                                </li>
                            }
                            @for (int i = 1; i <= Model.PageCount; i++)
                            {
                                <li class="page-item @(i == Model.PageNumber ? "active" : "")">
                                    <a class="page-link" asp-action="AllRooms"
                                       asp-route-page="@i"
                                       asp-route-keyword="@ViewBag.Keyword"
                                       asp-route-minPrice="@ViewBag.MinPrice"
                                       asp-route-maxPrice="@ViewBag.MaxPrice">@i</a>
                                </li>
                            }
                            @if (Model.HasNextPage)
                            {
                                <li class="page-item">
                                    <a class="page-link" asp-action="AllRooms"
                                       asp-route-page="@(Model.PageNumber + 1)"
                                       asp-route-keyword="@ViewBag.Keyword"
                                       asp-route-minPrice="@ViewBag.MinPrice"
                                       asp-route-maxPrice="@ViewBag.MaxPrice">
                                        <i class="bi bi-chevron-right"></i>
                                    </a>
                                </li>
                            }
                        </ul>
                    </nav>
                }
            }
            else
            {
                <div class="empty-state widget py-5">
                    <i class="bi bi-house-slash"></i>
                    <p class="fw-bold">Không tìm thấy phòng nào phù hợp</p>
                    <p style="font-size:0.85rem; color:#94a3b8;">Thử thay đổi bộ lọc hoặc kiểm tra lại sau.</p>
                    <a asp-controller="Home" asp-action="AllRooms" class="btn btn-sm btn-outline-secondary rounded-pill">
                        Xem tất cả phòng
                    </a>
                </div>
            }
        </div><!-- /MAIN CONTENT -->
    </div><!-- /row -->
</div>
