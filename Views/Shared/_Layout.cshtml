<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Quản Lý Phòng Trọ</title>

    <!-- Google Fonts: Inter -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">

    <!-- Bootstrap 5 -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />

    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" />

    <!-- Custom CSS -->
    <link rel="stylesheet" href="~/css/admin.css" asp-append-version="true" />

    @await RenderSectionAsync("Styles", required: false)
</head>
<body class="admin-body">
    <!-- Sidebar -->
    <aside class="admin-sidebar" id="adminSidebar">
        <div class="sidebar-brand">
            <div class="brand-icon">
                <i class="bi bi-buildings"></i>
            </div>
            <div class="brand-text">
                <span class="brand-name">QLPT</span>
                <span class="brand-sub">Quản lý Phòng Trọ</span>
            </div>
        </div>

        <nav class="sidebar-nav">
            <div class="nav-section">
                <span class="nav-section-label">TỔNG QUAN</span>
                <a asp-controller="Dashboard" asp-action="Index" class="nav-item @(IsActive("Dashboard", "Index"))">
                    <i class="bi bi-speedometer2"></i>
                    <span>Dashboard</span>
                </a>
            </div>

            <div class="nav-section">
                <span class="nav-section-label">QUẢN LÝ NHÀ</span>
                <a asp-controller="Properties" asp-action="Index" class="nav-item @(IsActive("Properties"))">
                    <i class="bi bi-house-door"></i>
                    <span>Khu Nhà / Dãy Trọ</span>
                </a>
                <a asp-controller="Rooms" asp-action="Index" class="nav-item @(IsActive("Rooms"))">
                    <i class="bi bi-door-closed"></i>
                    <span>Danh Sách Phòng</span>
                </a>
            </div>

            <div class="nav-section">
                <span class="nav-section-label">KHÁCH THUÊ</span>
                <a asp-controller="Tenants" asp-action="Index" class="nav-item @(IsActive("Tenants"))">
                    <i class="bi bi-people"></i>
                    <span>Khách Thuê</span>
                </a>
                <a asp-controller="Contracts" asp-action="Index" class="nav-item @(IsActive("Contracts"))">
                    <i class="bi bi-file-text"></i>
                    <span>Hợp Đồng</span>
                </a>
                <a asp-controller="MaintenanceTickets" asp-action="Index" class="nav-item @(IsActive("MaintenanceTickets"))">
                    <i class="bi bi-tools"></i>
                    <span>Báo Cáo Sự Cố</span>
                </a>
            </div>

            <div class="nav-section">
                <span class="nav-section-label">TÀI CHÍNH</span>
                <a asp-controller="Invoices" asp-action="Index" class="nav-item @(IsActive("Invoices"))">
                    <i class="bi bi-receipt"></i>
                    <span>Hóa Đơn</span>
                </a>
                <a asp-controller="Reports" asp-action="Index" class="nav-item @(IsActive("Reports"))">
                    <i class="bi bi-bar-chart-line"></i>
                    <span>Báo Cáo</span>
                </a>
                <a asp-controller="Invoices" asp-action="AuditLog" class="nav-item @(IsActive("Invoices", "AuditLog"))">
                    <i class="bi bi-clock-history"></i>
                    <span>Lịch Sử</span>
                </a>
            </div>
        </nav>
    </aside>

    <!-- Main Content -->
    <div class="admin-main" id="adminMain">
        <!-- Top Header -->
        <header class="admin-header">
            <button class="header-toggle" id="sidebarToggle" title="Toggle Sidebar">
                <i class="bi bi-list"></i>
            </button>

            <div class="header-breadcrumb">
                <span class="breadcrumb-text">@(ViewData["Title"] ?? "Dashboard")</span>
            </div>

            <div class="header-actions">
                <partial name="_LoginPartial" />
            </div>
        </header>

        <!-- Page Content -->
        <main class="admin-content">
            @RenderBody()
        </main>
    </div>

    <!-- Global Toast Notifications -->
    @if (TempData["Success"] != null)
    {
        <div class="toast-container-qlpt" id="globalToast">
            <div class="toast-qlpt toast-success">
                <i class="bi bi-check-circle-fill text-success"></i>
                <span>@TempData["Success"]</span>
            </div>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="toast-container-qlpt" id="globalToast">
            <div class="toast-qlpt toast-error">
                <i class="bi bi-x-circle-fill text-danger"></i>
                <span>@TempData["Error"]</span>
            </div>
        </div>
    }

    <!-- Scripts -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/admin.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
    <script>
        // Auto-dismiss global toast
        (function() {
            const toast = document.getElementById('globalToast');
            if (toast) {
                setTimeout(() => {
                    toast.style.transition = 'opacity 0.4s';
                    toast.style.opacity = '0';
                    setTimeout(() => toast.remove(), 400);
                }, 3500);
            }
        })();
    </script>
</body>
</html>

@functions {
    string IsActive(string controller, string? action = null)
    {
        var currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
        var currentAction = ViewContext.RouteData.Values["action"]?.ToString() ?? "";
        if (action == null)
            return currentController.Equals(controller, StringComparison.OrdinalIgnoreCase) ? "active" : "";
        return (currentController.Equals(controller, StringComparison.OrdinalIgnoreCase) &&
                currentAction.Equals(action, StringComparison.OrdinalIgnoreCase)) ? "active" : "";
    }
}
