<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Cổng Khách Thuê</title>
    <!-- Mượn tạm CSS của Admin -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/admin.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
</head>
<body class="admin-body">
    <!-- Sidebar -->
    <div class="admin-sidebar" id="sidebar">
        <div class="sidebar-brand">
            <i class="bi bi-person-badge text-primary"></i> <span style="color:#2d3748;">Khách Thuê</span>
        </div>
        
        <div class="sidebar-user mb-4 pb-4 border-bottom px-3 text-center">
            <div style="width: 48px; height: 48px; border-radius: 50%; background: #e2e8f0; display: inline-flex; align-items: center; justify-content: center; margin-bottom: 10px;">
                <i class="bi bi-person text-secondary fs-4"></i>
            </div>
            <div style="font-size: 14px; font-weight: 600; color: #4a5568;">@User.Identity?.Name</div>
            <div style="font-size: 12px; color: #718096;">Khách thuê</div>
            <form method="post" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })" class="mt-2 text-center">
                <button type="submit" class="btn btn-sm btn-outline-danger" style="font-size: 0.75rem;"><i class="bi bi-box-arrow-right"></i> Đăng xuất</button>
            </form>
        </div>

        <nav class="sidebar-menu">
            <a href="@Url.Action("Index", "TenantDashboard")"
               class="menu-item @(ViewContext.RouteData.Values["Controller"]?.ToString() == "TenantDashboard" && ViewContext.RouteData.Values["Action"]?.ToString() == "Index" ? "active" : "")">
                <i class="bi bi-speedometer2"></i> Tổng Quan
            </a>
            <a href="@Url.Action("Index", "MaintenanceTickets")"
               class="menu-item @(ViewContext.RouteData.Values["Controller"]?.ToString() == "MaintenanceTickets" && ViewContext.RouteData.Values["Action"]?.ToString() == "Index" ? "active" : "")">
                <i class="bi bi-clipboard2-check"></i> Phiếu Bảo Trì
            </a>
            <a href="@Url.Action("Create", "MaintenanceTickets")"
               class="menu-item @(ViewContext.RouteData.Values["Controller"]?.ToString() == "MaintenanceTickets" && ViewContext.RouteData.Values["Action"]?.ToString() == "Create" ? "active" : "")">
                <i class="bi bi-plus-square"></i> Gửi Phiếu Mới
            </a>
        </nav>
        
        <div class="mt-auto px-4 py-3 text-center">
            <a href="/" class="btn btn-sm btn-outline-secondary w-100">
                <i class="bi bi-house"></i> Về Trang Chủ
            </a>
        </div>
    </div>

    <!-- Main Content -->
    <div class="admin-main" id="main-content">
        <!-- Top Navbar -->
        <nav class="admin-topbar">
            <button class="btn btn-link text-dark" id="sidebar-toggle">
                <i class="bi bi-list fs-4"></i>
            </button>
            <div class="ms-auto pe-4"></div>
        </nav>

        <div class="admin-container">
            <main role="main">
                @RenderBody()
            </main>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        $(document).ready(function() {
            $('#sidebar-toggle').click(function() {
                $('#sidebar').toggleClass('collapsed');
                $('#main-content').toggleClass('expanded');
            });
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
