@model X.PagedList.IPagedList<Website_QLPT.Models.Tenant>
@using X.PagedList.Mvc.Core
@{
    ViewData["Title"] = "Khách Thuê";
}

@if (TempData["Success"] != null)
{
    <div class="toast-container-qlpt">
        <div class="toast-qlpt toast-success">
            <i class="bi bi-check-circle-fill text-success"></i>
            <span>@TempData["Success"]</span>
        </div>
    </div>
}

<div class="page-header">
    <h1 class="page-title"><i class="bi bi-people me-2 text-secondary"></i>Danh Sách Khách Thuê</h1>
    <a asp-action="Create" class="btn-qlpt btn-qlpt-primary"><i class="bi bi-plus-lg"></i> Thêm khách thuê</a>
</div>

@* Search *@
<div class="card-qlpt mb-3">
    <div class="card-qlpt-body py-3">
        <form method="get" asp-action="Index" class="row g-2 align-items-end">
            <div class="col-sm-6">
                <label class="form-label" style="font-size:12px;font-weight:600;color:#6b7280;">Tìm kiếm</label>
                <input type="text" name="search" value="@ViewBag.Search" class="form-control form-control-sm"
                       placeholder="Nhập tên, số CCCD hoặc số điện thoại..." />
            </div>
            <div class="col-sm-2">
                <button type="submit" class="btn-qlpt btn-qlpt-primary w-100" style="justify-content:center;">
                    <i class="bi bi-search"></i> Tìm
                </button>
            </div>
            @if (!string.IsNullOrEmpty(ViewBag.Search as string))
            {
                <div class="col-sm-2">
                    <a asp-action="Index" class="btn-qlpt btn-qlpt-secondary w-100" style="justify-content:center;">
                        <i class="bi bi-x-circle"></i> Xóa lọc
                    </a>
                </div>
            }
        </form>
    </div>
</div>

<div class="card-qlpt">
    @if (Model.Any())
    {
        <div class="table-responsive">
            <table class="table-qlpt">
                <thead>
                    <tr>
                        <th>Họ và Tên</th>
                        <th>Email</th>
                        <th>Số CCCD</th>
                        <th>Số điện thoại</th>
                        <th>Liên kết tài khoản</th>
                        <th>Quê quán</th>
                        <th>Ngày tạo</th>
                        <th>Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var tenant in Model)
                    {
                        <tr>
                            <td>
                                <div class="d-flex align-items-center gap-2">
                                    <div style="width:32px;height:32px;background:#e5e7eb;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:14px;font-weight:600;color:#6b7280;flex-shrink:0;">
                                        @tenant.FullName[0].ToString().ToUpper()
                                    </div>
                                    <strong>@tenant.FullName</strong>
                                </div>
                            </td>
                            <td class="text-muted">@(tenant.Email ?? "--")</td>
                            <td class="text-muted">@(tenant.NationalId ?? "--")</td>
                            <td class="text-muted">@(tenant.PhoneNumber ?? "--")</td>
                            <td>
                                @if (tenant.IdentityUser != null)
                                {
                                    <div class="d-flex flex-column">
                                        <span class="badge-qlpt badge-available"><i class="bi bi-link-45deg"></i> Đã liên kết</span>
                                        <small class="text-muted mt-1">@tenant.IdentityUser.Email</small>
                                    </div>
                                }
                                else
                                {
                                    <div class="d-flex flex-column">
                                        <span class="badge bg-warning text-dark"><i class="bi bi-clock-history"></i> Chờ liên kết</span>
                                        <small class="text-muted mt-1">Chưa gắn tài khoản</small>
                                    </div>
                                }
                            </td>
                            <td class="text-muted" style="max-width:200px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;" title="@tenant.HomeTown">
                                @(tenant.HomeTown ?? "--")
                            </td>
                            <td class="text-muted">@tenant.CreatedAt.ToString("dd/MM/yyyy")</td>
                            <td>
                                <div class="d-flex gap-2">
                                    <a asp-action="Edit" asp-route-id="@tenant.Id" class="btn-qlpt btn-qlpt-secondary btn-qlpt-sm"><i class="bi bi-pencil"></i></a>
                                    <form asp-action="Delete" asp-route-id="@tenant.Id" method="post"
                                          onsubmit="return confirm('Xóa khách thuê \'@tenant.FullName\'? Hành động này không thể hoàn tác.')">
                                        @Html.AntiForgeryToken()
                                        <button class="btn-qlpt btn-qlpt-danger btn-qlpt-sm"><i class="bi bi-trash"></i></button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        @if (Model.PageCount > 1)
        {
            <div class="card-qlpt-body border-top py-3 d-flex justify-content-between align-items-center">
                <div class="text-muted small">
                    Hiển thị @Model.FirstItemOnPage đến @Model.LastItemOnPage trong tổng số @Model.TotalItemCount khách thuê
                </div>
                <div>
                    @Html.PagedListPager(Model, page => Url.Action("Index", new { page, search = ViewBag.Search }),
                    new PagedListRenderOptions {
                        LiElementClasses = new string[] { "page-item" },
                        PageClasses = new string[] { "page-link" },
                        UlElementClasses = new string[] { "pagination", "pagination-sm", "mb-0" }
                    })
                </div>
            </div>
        }
    }
    else
    {
        <div class="card-qlpt-body text-center py-5 text-muted">
            <i class="bi bi-people fs-2 d-block mb-2"></i>
            @if (!string.IsNullOrEmpty(ViewBag.Search as string))
            {
                <span>Không tìm thấy khách thuê nào. <a asp-action="Index">Xem tất cả</a></span>
            }
            else
            {
                <span>Chưa có khách thuê nào. <a asp-action="Create">Thêm khách thuê mới</a></span>
            }
        </div>
    }
</div>
