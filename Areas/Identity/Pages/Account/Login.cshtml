@page
@model LoginModel

@{
    ViewData["Title"] = "Log in";
}

<div class="auth-card">
    <div class="auth-brand">
        <div class="brand-icon">
            <i class="bi bi-buildings"></i>
        </div>
        <h1 class="brand-name">QLPT</h1>
        <p class="brand-sub">Hệ thống Quản lý Phòng trọ</p>
    </div>

    <h2 class="h5 text-center mb-4 text-secondary">Đăng nhập hệ thống</h2>

    <form id="account" method="post">
        <div asp-validation-summary="ModelOnly" class="text-danger small mb-3" role="alert"></div>
        <div class="form-floating mb-3">
            <input asp-for="Input.Email" class="form-control" autocomplete="username" aria-required="true" placeholder="name@example.com" />
            <label asp-for="Input.Email">Email</label>
            <span asp-validation-for="Input.Email" class="text-danger small"></span>
        </div>
        <div class="form-floating mb-3">
            <input asp-for="Input.Password" class="form-control" autocomplete="current-password" aria-required="true" placeholder="password" />
            <label asp-for="Input.Password">Mật khẩu</label>
            <span asp-validation-for="Input.Password" class="text-danger small"></span>
        </div>
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div class="form-check">
                <input class="form-check-input" asp-for="Input.RememberMe" />
                <label class="form-check-label text-muted small" asp-for="Input.RememberMe">
                    Ghi nhớ
                </label>
            </div>
            <div class="auth-links">
                <a id="forgot-password" asp-page="./ForgotPassword">Quên mật khẩu?</a>
            </div>
        </div>
        <button id="login-submit" type="submit" class="w-100 btn btn-primary mb-4">Đăng nhập</button>

        <div class="text-center auth-links text-muted small">
            Chưa có tài khoản? <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl">Đăng ký ngay</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
