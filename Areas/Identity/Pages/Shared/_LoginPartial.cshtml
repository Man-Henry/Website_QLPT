@using Microsoft.AspNetCore.Identity
@inject SignInManager<IdentityUser> SignInManager
@inject UserManager<IdentityUser> UserManager

@if (SignInManager.IsSignedIn(User))
{
    <form asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })" method="post">
        <button type="submit" class="btn btn-outline-secondary btn-sm">
            Đăng xuất (@User.Identity?.Name)
        </button>
    </form>
}
else
{
    <a asp-area="Identity" asp-page="/Account/Register" class="btn btn-outline-secondary btn-sm me-2">Đăng ký</a>
    <a asp-area="Identity" asp-page="/Account/Login" class="btn btn-primary btn-sm">Đăng nhập</a>
}
